# ─── Application ────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
LOG_LEVEL=INFO

# ─── Security ────────────────────────────────────────────────────
JWT_SECRET=development-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080       # 7 days

# ─── Google Cloud ────────────────────────────────────────────────
GCP_PROJECT=math-mentor-agent
GCP_REGION=us-central1
# Path to service account JSON (or use: gcloud auth application-default login)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#
# Required once per GCP project:
#   1. Enable Vertex AI API: https://console.cloud.google.com/apis/library/aiplatform.googleapis.com
#   2. Billing enabled on the project
#   3. Service account needs roles/aiplatform.user (or Vertex AI User)

# ─── Vertex AI / Gemini ──────────────────────────────────────────
VERTEX_LOCATION=us-central1
GEMINI_MODEL_PRO=gemini-2.0-pro-001
GEMINI_MODEL_FLASH=gemini-2.0-flash-001
VERTEX_TIMEOUT_PRO=15.0        # seconds
VERTEX_TIMEOUT_FLASH=5.0

# ─── DeepSeek (optional alternative LLM) ────────────────────────
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL_PRO=deepseek-reasoner
# DEEPSEEK_MODEL_FLASH=deepseek-chat
# DEEPSEEK_TIMEOUT_PRO=60.0
# DEEPSEEK_TIMEOUT_FLASH=30.0

# ─── MongoDB Atlas ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=mathmentor

# ─── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://mathmentor-web.run.app

# ─── Google OAuth ────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
